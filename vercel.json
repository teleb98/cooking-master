{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/ai/chat.js":          { "maxDuration": 60 },
    "api/ai/generate-plan.js": { "maxDuration": 60 },
    "api/recipes/index.js":    { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/user/profile?cron=notify", "schedule": "0 11 * * *" }
  ]
}
