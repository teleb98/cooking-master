# ── Database ───────────────────────────────────────────────────────────────
# PostgreSQL (production) — get a free connection string from https://neon.tech
# Leave unset to use SQLite (local dev, no setup required)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Auth ────────────────────────────────────────────────────────────────────
# JWT signing key — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-before-deploying

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
